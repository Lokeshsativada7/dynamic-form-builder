# Backend Environment Variables
# Copy this file to .env for local development
# In production (Render/Heroku), add these variables to your Environment settings

# The port your server runs on (Render automatically assigns this)
PORT=5000

# Your MongoDB Atlas Connection String
# Get this by creating a free cluster on https://www.mongodb.com/cloud/atlas/register
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dynamic_forms
MONGO_URI=mongodb://127.0.0.1:27017/dynamic_forms
